# ──────────────────────────────────────────────────────────────
# Backend (NestJS) environment template.
# Copy to `backend/.env` for local development. `.env` is git-ignored.
# In Docker these values are injected by docker-compose from the root .env.
# ──────────────────────────────────────────────────────────────

NODE_ENV=development

# ── HTTP server ──
API_PORT=3000
API_GLOBAL_PREFIX=api
CORS_ORIGINS=http://localhost:4200

# ── Database (MySQL) ──
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nard_inventory
DB_USERNAME=nard
DB_PASSWORD=nard_local_dev

# ── JWT ──
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
