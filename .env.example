# ──────────────────────────────────────────────────────────────
# Nard Inventory & Sales Management System — environment template
# Copy to `.env` and adjust. `.env` is git-ignored.
# ──────────────────────────────────────────────────────────────

# ── Database (MySQL) ──
DB_HOST=localhost
DB_PORT=3306
DB_ROOT_PASSWORD=change_me_root
DB_DATABASE=nard_inventory
DB_USERNAME=nard
DB_PASSWORD=change_me

# ── Backend (NestJS API) ──
NODE_ENV=development
API_PORT=3000
API_GLOBAL_PREFIX=api

# JWT — use long, random secrets in production
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4200

# ── Frontend (Angular) ──
WEB_PORT=4200
